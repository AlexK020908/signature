# Copy to ".env" and fill in. Never commit the real .env.

# From https://my.telegram.org -> API development tools
TELEGRAM_API_ID=1234567
TELEGRAM_API_HASH=0123456789abcdef0123456789abcdef

# The channel to monitor. Any of these work:
#   @somepickschannel           (public username)
#   https://t.me/somechannel    (public link)
#   -1001234567890              (numeric id, for private channels)
# For a PRIVATE channel without a username, use the numeric id.
# Tip: set LOG_LEVEL=DEBUG and the script logs the id of the channel it sees.
TELEGRAM_CHANNEL=@somepickschannel

# Discord -> Server Settings -> Integrations -> Webhooks -> New Webhook -> Copy URL
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/XXXX/YYYY

# "@here", "@everyone", or leave blank for no ping
DISCORD_MENTION=@here

# Optional
TELEGRAM_SESSION=forwarder_session
LOG_LEVEL=INFO

# On startup, immediately forward the most recent existing post(s) so you see
# the latest pick right away. Set FORWARD_LAST_ON_START=false to disable.
# FORWARD_LAST_COUNT controls how many recent posts to send on start (default 1).
FORWARD_LAST_ON_START=true
FORWARD_LAST_COUNT=1
