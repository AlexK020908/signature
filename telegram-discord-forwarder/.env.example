# Copy to ".env" and fill in. Never commit the real .env.

# From https://my.telegram.org -> API development tools
TELEGRAM_API_ID=1234567
TELEGRAM_API_HASH=0123456789abcdef0123456789abcdef

# The channel(s) to monitor. Any of these work:
#   @somepickschannel           (public username)
#   https://t.me/somechannel    (public link)
#   -1001234567890              (numeric id, for private channels)
# For a PRIVATE channel without a username, use the numeric id.
# Tip: set LOG_LEVEL=DEBUG and the script logs the id of the channel it sees.
#
# To watch MULTIPLE channels, comma-separate them, e.g.:
#   TELEGRAM_CHANNEL=@channelone, @channeltwo, -1001234567890
TELEGRAM_CHANNEL=@somepickschannel

# Discord -> Server Settings -> Integrations -> Webhooks -> New Webhook -> Copy URL
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/XXXX/YYYY

# "@here", "@everyone", or leave blank for no ping
DISCORD_MENTION=@here

# --- Discord-based Telegram login (so the server never needs terminal input) -
# Only used the FIRST time, when there's no valid Telegram session yet. The bot
# asks for your phone + code in a Discord channel; you reply there.
#
# 1. https://discord.com/developers/applications -> New Application -> Bot
#    -> Reset Token -> copy it here.
# 2. On that Bot page, enable "MESSAGE CONTENT INTENT" (required to read replies).
# 3. OAuth2 -> URL Generator -> scopes: bot -> invite it to your server.
# 4. In Discord, enable Developer Mode (Settings -> Advanced), right-click the
#    channel the bot can see -> Copy Channel ID -> paste below.
DISCORD_BOT_TOKEN=
DISCORD_AUTH_CHANNEL_ID=
# Optional: lock replies to only your Discord user (right-click your name ->
# Copy User ID). Leave blank to accept replies from anyone in the channel.
DISCORD_OWNER_ID=

# Optional
TELEGRAM_SESSION=forwarder_session
LOG_LEVEL=INFO

# On startup, immediately forward the most recent existing post(s) so you see
# the latest pick right away. Set FORWARD_LAST_ON_START=false to disable.
# FORWARD_LAST_COUNT controls how many recent posts to send on start (default 1).
FORWARD_LAST_ON_START=true
FORWARD_LAST_COUNT=1
